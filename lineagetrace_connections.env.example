# LineageTrace connection profile
# Copy this file to lineagetrace_connections.env and fill in the project you want.
# The real lineagetrace_connections.env file is intentionally ignored by git.

# A human label for your own bookkeeping. The app does not require this.
LINEAGETRACE_ENVIRONMENT=local-beta

# Local browser sessions need a stable secret so login sessions survive restarts.
# Generate a long random string for real use.
LINEAGETRACE_WEB_SECRET=replace-with-a-long-random-string

# Active backend connection.
# local    = local SQLite database
# supabase = Supabase Auth + Postgres + RLS
SLIDEAPP_CONNECTION_MODE=supabase

# Supabase project values from Project Settings > API.
# These are safe public client values when Row Level Security is enabled.
SLIDEAPP_SUPABASE_LABEL=LineageTrace
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Friendly app-level early rejection after Supabase/Google sign-in.
# The real database write gate is public.authorized_users plus RLS.
# Keep this list in sync with public.authorized_users for clearer login messages.
# If this is blank, the app defers entirely to Supabase/RLS authorization.
LINEAGETRACE_AUTHORIZED_EMAILS=owner@example.com,admin@example.com,researcher@example.com

# Optional display aliases for legacy rows that stored an email in a name column.
# Format: email@example.com=Display Name,another@example.com=Another Name
LINEAGETRACE_DISPLAY_NAME_OVERRIDES=owner@example.com=Owner

# Google OAuth is configured inside Supabase under Authentication > Providers.
# The local app normally does not need the Google client secret.
# Keep these optional notes here so a future maintainer knows which Google app
# belongs to this Supabase project, without requiring code changes.
GOOGLE_OAUTH_PROJECT_ID=your-google-cloud-project-id
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET should stay in Supabase/Google Cloud, not committed.

# Required redirect URLs to allow in Supabase/Google Cloud for local testing:
# http://127.0.0.1:8010/auth/callback
# http://localhost:8010/auth/callback
