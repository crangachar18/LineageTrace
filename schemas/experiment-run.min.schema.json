{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "experiment-run.min.schema.json",
  "type": "object",
  "required": [
    "run_id",
    "experiment_type",
    "run_name",
    "created_by",
    "created_at",
    "workflow_stage",
    "records"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment_type": {
      "type": "string",
      "enum": [
        "IHC",
        "PCR",
        "CLONING",
        "EANDC",
        "BULK_RNA",
        "CDNA",
        "OTHER"
      ]
    },
    "run_name": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "workflow_stage": {
      "type": "string",
      "enum": [
        "draft",
        "in_progress",
        "awaiting_colony_pick",
        "completed"
      ]
    },
    "parent_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "lineage-record.min.schema.json"
      }
    },
    "run_attributes": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
